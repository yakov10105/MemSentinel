{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Sentinel": {
    "TargetProcessName": "dotnet",
    "PollingIntervalSeconds": 5,
    "CoolingPeriodMinutes": 3,
    "StorageProvider": "Local",
    "Thresholds": {
      "RssLimitPercentage": 80.0,
      "Gen2GrowthLimitMb": 100.0
    }
  }
}
