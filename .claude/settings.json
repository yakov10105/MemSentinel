{
  "permissions": {
    "allow": [
      "Bash(dotnet build)",
      "Bash(dotnet build*)",
      "Bash(dotnet test*)",
      "Bash(dotnet run*)",
      "Bash(dotnet restore)",
      "Bash(dotnet format*)",
      "Bash(dotnet publish*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git stash*)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(git push --force*)",
      "Bash(dotnet nuget push*)",
      "Bash(kubectl delete*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "dotnet build --no-restore 2>&1 | tail -5"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session complete. Run /clear before starting a new unrelated task.'"
          }
        ]
      }
    ]
  },
  "env": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_NOLOGO": "1"
  }
}
